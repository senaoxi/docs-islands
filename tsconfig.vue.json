{
  "$schema": "https://json.schemastore.org/tsconfig",
  // Root Vue checker route for source-owned docs and theme SFC projects.
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "declaration": false,
    "isolatedDeclarations": false,
    "jsx": "preserve",
    "types": ["vite/client"]
  },
  "include": [
    "docs/**/*",
    "packages/vitepress/docs/**/*",
    "packages/vitepress/theme/**/*"
  ]
}
