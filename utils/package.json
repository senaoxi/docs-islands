{
  "name": "@docs-islands/utils",
  "private": true,
  "version": "0.2.5",
  "type": "module",
  "license": "MIT",
  "author": "Senao Xi",
  "description": "Shared runtime and build utilities for docs-islands packages",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "link-guard": "./bin/link-guard.js"
  },
  "scripts": {
    "build": "del-cli dist && limina build tsconfig.dts.json --checker tsgo",
    "build:watch": "tsc -b tsconfig.dts.json -w",
    "test": "vitest run",
    "typecheck": "limina checker build",
    "lint": "eslint . --config ./eslint.config.mjs --fix --cache",
    "clean": "del-cli .tsbuild .eslintcache dist node_modules"
  },
  "dependencies": {
    "@pnpm/exportable-manifest": "catalog:prod",
    "@pnpm/workspace.read-manifest": "catalog:prod",
    "logaria": "catalog:prod",
    "tinyglobby": "catalog:prod"
  },
  "devDependencies": {
    "eslint": "catalog:lint",
    "@pnpm/catalogs.types": "catalog:dev",
    "@pnpm/pnpmfile": "catalog:dev",
    "@types/picomatch": "catalog:dev",
    "@docs-islands/eslint-config": "workspace:*",
    "limina": "workspace:*",
    "typescript": "catalog:dev",
    "pathe": "catalog:dev",
    "is-in-ci": "catalog:dev",
    "zod": "catalog:dev",
    "del-cli": "catalog:dev",
    "vite": "catalog:prod",
    "vitest": "catalog:test"
  },
  "exports": {
    "./builtin": "./dist/src/builtin.js",
    "./dom-iterable": "./dist/src/dom-iterable.js",
    "./env": "./dist/src/env.js",
    "./fs-utils": "./dist/src/fs-utils.js",
    "./general": "./dist/src/general.js",
    "./logger": "./dist/src/logger.js",
    "./package-plugin": "./dist/src/package-plugin.js",
    "./path": "./dist/src/path.js",
    "./package.json": "./package.json"
  },
  "sideEffects": false
}
