{
  "name": "@docs-islands/utils",
  "private": true,
  "version": "0.2.5",
  "type": "module",
  "license": "MIT",
  "author": "Senao Xi",
  "description": "Shared runtime and build utilities for docs-islands packages",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "link-guard": "./bin/link-guard.js"
  },
  "scripts": {
    "build": "rolldown --config rolldown.config.ts",
    "build:watch": "rolldown --config rolldown.config.ts --watch",
    "test": "vitest run",
    "typecheck": "limina checker typecheck",
    "lint": "eslint . --config ./eslint.config.mjs --fix --cache",
    "clean": "del-cli .tsbuild .eslintcache dist node_modules"
  },
  "dependencies": {
    "logaria": "npm:@docs-islands/logger@latest",
    "tinyglobby": "catalog:prod"
  },
  "devDependencies": {
    "eslint": "catalog:lint",
    "@types/picomatch": "catalog:dev",
    "@docs-islands/eslint-config": "workspace:*",
    "typescript": "catalog:dev",
    "pathe": "catalog:dev",
    "is-in-ci": "catalog:dev",
    "zod": "catalog:dev",
    "del-cli": "catalog:dev",
    "vite": "catalog:prod",
    "rolldown": "catalog:dev",
    "rolldown-plugin-dts": "catalog:dev",
    "vitest": "catalog:test"
  },
  "exports": {
    "./builtin": "./src/builtin.ts",
    "./dom-iterable": "./src/dom-iterable.ts",
    "./env": "./src/env.ts",
    "./fs-utils": "./src/fs-utils.ts",
    "./general": "./src/general.ts",
    "./logger": "./src/logger.ts",
    "./path": "./src/path.ts",
    "./package.json": "./package.json"
  },
  "sideEffects": false
}
