{
  "$schema": "https://json.schemastore.org/tsconfig",
  // Tools declaration leaf for package build/config files; depends on library declaration leaves.
  "extends": ["./tsconfig.tools.json", "../tsconfig.dts.base.json"],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./.tsbuild",
    "tsBuildInfoFile": "./.tsbuild/tools.tsbuildinfo"
  },
  "references": [
    {
      "path": "./tsconfig.lib.dts.json"
    }
  ]
}
