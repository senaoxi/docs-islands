{
  // Vue SFC check used by vue-tsc via pnpm typecheck:vue; not native tsc -b.
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "allowJs": true,
    "isolatedDeclarations": false,
    "declaration": false,
  },
  "include": [
    "./",
    "./package.json",
    "./client.d.ts",
    "./.vitepress/**/*.ts",
    "./.vitepress/theme/**/*.vue",
  ],
}
