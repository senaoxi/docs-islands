{
  // Package-local tooling check. Declaration leaf: tsconfig.tools.dts.json.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "isolatedDeclarations": false,
    "declaration": true,
    "lib": ["ES2023"],
    "types": ["node"]
  },
  "include": [
    "package.json",
    "packagePlugin.ts",
    "rolldown.config.ts",
    "scripts/**/*.ts"
  ]
}
