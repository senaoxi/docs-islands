{
  "name": "limina",
  "version": "0.0.4",
  "type": "module",
  "license": "MIT",
  "author": "Senao Xi",
  "description": "Configurable monorepo architecture and TypeScript graph governance CLI",
  "files": [
    "bin",
    "LICENSE.md",
    "README.md",
    "README.zh-CN.md",
    "schemas"
  ],
  "keywords": [
    "monorepo",
    "typescript",
    "project-references",
    "workspace",
    "architecture"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XiSenao/docs-islands.git",
    "directory": "packages/limina"
  },
  "bugs": {
    "url": "https://github.com/XiSenao/docs-islands/issues"
  },
  "homepage": "https://docs.senao.me/docs-islands",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "limina": "./bin/limina.js"
  },
  "scripts": {
    "build": "rolldown --config rolldown.config.ts",
    "build:watch": "rolldown --config rolldown.config.ts --watch",
    "typecheck": "node bin/limina.js checker build",
    "test": "vitest run",
    "lint": "eslint . --config ./eslint.config.mjs --fix --cache --cache-location ./node_modules/.cache/eslint/",
    "clean": "del-cli .tsbuild .eslintcache dist coverage node_modules"
  },
  "dependencies": {
    "@arethetypeswrong/core": "catalog:lint",
    "@clack/prompts": "catalog:dev",
    "logaria": "catalog:prod",
    "@publint/pack": "catalog:lint",
    "cac": "catalog:dev",
    "es-module-lexer": "catalog:dev",
    "knip": "catalog:lint",
    "npm-package-json-lint": "catalog:lint",
    "picomatch": "catalog:prod",
    "publint": "catalog:lint",
    "semver": "catalog:dev",
    "tinyglobby": "catalog:prod",
    "yaml": "catalog:dev",
    "zod": "catalog:dev"
  },
  "devDependencies": {
    "@docs-islands/eslint-config": "workspace:*",
    "@docs-islands/utils": "link:../../utils/dist",
    "@docs-islands/plugin-license": "link:../plugins/license/dist",
    "@vue/compiler-sfc": "catalog:dev",
    "@types/node": "catalog:dev",
    "del-cli": "catalog:dev",
    "eslint": "catalog:lint",
    "rolldown": "catalog:dev",
    "rolldown-plugin-dts": "catalog:dev",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:test"
  },
  "peerDependencies": {
    "@typescript/native-preview": "catalog:dev",
    "@vue/compiler-sfc": "catalog:dev",
    "svelte-check": "catalog:dev",
    "typescript": "catalog:dev",
    "vue-tsc": "catalog:dev",
    "vue-tsgo": "catalog:dev"
  },
  "peerDependenciesMeta": {
    "@typescript/native-preview": {
      "optional": true
    },
    "@vue/compiler-sfc": {
      "optional": true
    },
    "svelte-check": {
      "optional": true
    },
    "typescript": {
      "optional": true
    },
    "vue-tsc": {
      "optional": true
    },
    "vue-tsgo": {
      "optional": true
    }
  },
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config.ts",
    "./schemas/tsconfig-schema.json": "./schemas/tsconfig-schema.json",
    "./package.json": "./package.json"
  },
  "sideEffects": false
}
