{
  "name": "limina",
  "version": "0.0.6",
  "type": "module",
  "license": "MIT",
  "author": "Senao Xi",
  "description": "Configurable monorepo architecture and TypeScript graph governance CLI",
  "files": [
    "bin",
    "LICENSE.md",
    "README.md",
    "README.zh-CN.md",
    "schemas"
  ],
  "keywords": [
    "monorepo",
    "typescript",
    "project-references",
    "workspace",
    "architecture"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XiSenao/docs-islands.git",
    "directory": "packages/limina"
  },
  "bugs": {
    "url": "https://github.com/XiSenao/docs-islands/issues"
  },
  "homepage": "https://docs.senao.me/docs-islands/limina",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "limina": "./bin/limina.js"
  },
  "scripts": {
    "build": "rolldown --config rolldown.config.ts",
    "build:watch": "rolldown --config rolldown.config.ts --watch",
    "typecheck": "node bin/limina.js checker build",
    "test": "vitest run",
    "smoke": "pnpm nx run limina:build && pnpm --dir ./smoke test",
    "lint": "eslint . --config ./eslint.config.mjs --fix --cache --cache-location ./node_modules/.cache/eslint/",
    "clean": "del-cli .tsbuild .eslintcache dist coverage node_modules"
  },
  "dependencies": {
    "picomatch": "catalog:prod",
    "tinyglobby": "catalog:prod",
    "oxc-parser": "catalog:prod",
    "oxc-resolver": "catalog:prod"
  },
  "devDependencies": {
    "@types/picomatch": "catalog:dev",
    "@types/semver": "catalog:dev",
    "@docs-islands/eslint-config": "workspace:*",
    "@docs-islands/utils": "workspace:*",
    "@docs-islands/plugin-license": "link:../plugins/license/dist",
    "@vue/compiler-sfc": "catalog:dev",
    "@types/node": "catalog:dev",
    "@arethetypeswrong/core": "catalog:lint",
    "@clack/prompts": "catalog:dev",
    "logaria": "catalog:prod",
    "@publint/pack": "catalog:lint",
    "cac": "catalog:dev",
    "es-module-lexer": "catalog:dev",
    "pathe": "catalog:dev",
    "ignore": "catalog:prod",
    "knip": "catalog:lint",
    "npm-package-json-lint": "catalog:lint",
    "publint": "catalog:lint",
    "semver": "catalog:dev",
    "yaml": "catalog:dev",
    "zod": "catalog:dev",
    "del-cli": "catalog:dev",
    "eslint": "catalog:lint",
    "rolldown": "catalog:dev",
    "rolldown-plugin-dts": "catalog:dev",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:test"
  },
  "peerDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@typescript/native-preview": "7.0.0-dev.20260527.1",
    "@vue/compiler-sfc": "^3.5.28",
    "knip": "^6.15.0",
    "publint": "^0.3.17",
    "svelte-check": "^4.4.7",
    "typescript": "~5.9.3",
    "vue-tsc": "~3.2.4",
    "vue-tsgo": "0.2.2"
  },
  "peerDependenciesMeta": {
    "@arethetypeswrong/core": {
      "optional": true
    },
    "@typescript/native-preview": {
      "optional": true
    },
    "@vue/compiler-sfc": {
      "optional": true
    },
    "knip": {
      "optional": true
    },
    "publint": {
      "optional": true
    },
    "svelte-check": {
      "optional": true
    },
    "typescript": {
      "optional": true
    },
    "vue-tsc": {
      "optional": true
    },
    "vue-tsgo": {
      "optional": true
    }
  },
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./config": "./src/config.ts",
    "./schemas/tsconfig-schema.json": "./schemas/tsconfig-schema.json",
    "./package.json": "./package.json"
  },
  "sideEffects": false
}
