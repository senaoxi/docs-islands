{
  "name": "limina",
  "version": "0.1.3",
  "type": "module",
  "license": "MIT",
  "author": "Senao Xi",
  "description": "Configurable monorepo architecture and TypeScript graph governance CLI",
  "files": [
    "bin",
    "LICENSE.md",
    "README.md",
    "README.zh-CN.md",
    "schemas"
  ],
  "keywords": [
    "monorepo",
    "typescript",
    "project-references",
    "workspace",
    "architecture"
  ],
  "engines": {
    "node": "^22.18.0 || >=24.11.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/senaoxi/docs-islands.git",
    "directory": "packages/limina"
  },
  "bugs": {
    "url": "https://github.com/senaoxi/docs-islands/issues"
  },
  "homepage": "https://docs.senao.me/docs-islands/limina",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "limina": "./bin/limina.js"
  },
  "imports": {
    "#utils/*": "./src/utils/*.ts",
    "#core": "./src/core/index.ts",
    "#core/*/runner": "./src/core/*/runner.ts",
    "#core/*/context": "./src/core/*/context.ts",
    "#core/*/actions": "./src/core/*/actions.ts",
    "#checkers": "./src/checkers.ts",
    "#config/*": "./src/config/*.ts"
  },
  "scripts": {
    "build": "rolldown --config rolldown.config.ts",
    "build:watch": "rolldown --config rolldown.config.ts --watch",
    "typecheck": "node bin/limina.js checker build",
    "test": "vitest run",
    "test:unit": "vitest run",
    "smoke": "pnpm nx run limina:build && pnpm --dir ./smoke test",
    "lint": "eslint . --config ./eslint.config.mjs --fix --cache --cache-location ./node_modules/.cache/eslint/",
    "clean": "del-cli .tsbuild .eslintcache dist coverage node_modules"
  },
  "dependencies": {
    "picomatch": "catalog:prod",
    "tinyglobby": "catalog:prod",
    "oxc-parser": "catalog:prod",
    "oxc-resolver": "catalog:prod"
  },
  "devDependencies": {
    "@types/picomatch": "catalog:dev",
    "@types/semver": "catalog:dev",
    "@docs-islands/eslint-config": "workspace:*",
    "@docs-islands/utils": "workspace:*",
    "@docs-islands/plugin-license": "workspace:*",
    "@vue/compiler-sfc": "catalog:dev",
    "@types/node": "catalog:dev",
    "@arethetypeswrong/core": "catalog:lint",
    "@clack/prompts": "catalog:dev",
    "boxen": "catalog:dev",
    "logaria": "workspace:*",
    "@publint/pack": "catalog:lint",
    "cac": "catalog:dev",
    "es-module-lexer": "catalog:dev",
    "pathe": "catalog:dev",
    "ignore": "catalog:prod",
    "knip": "catalog:lint",
    "npm-package-json-lint": "catalog:lint",
    "publint": "catalog:lint",
    "semver": "catalog:dev",
    "@pnpm/workspace.read-manifest": "catalog:dev",
    "yaml": "catalog:dev",
    "zod": "catalog:dev",
    "del-cli": "catalog:dev",
    "eslint": "catalog:lint",
    "rolldown": "catalog:dev",
    "rolldown-plugin-dts": "catalog:dev",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:test"
  },
  "peerDependencies": {
    "@arethetypeswrong/core": "^0.18.0",
    "@typescript/native-preview": ">=7.0.0-dev.20260527.1 <7.0.0",
    "@vue/compiler-sfc": "^3.5.0",
    "knip": "^6.15.0",
    "publint": "^0.3.0",
    "svelte-check": "^4.4.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.0",
    "vue-tsc": "^3.2.4",
    "vue-tsgo": "^0.2.2"
  },
  "peerDependenciesMeta": {
    "@arethetypeswrong/core": {
      "optional": true
    },
    "@typescript/native-preview": {
      "optional": true
    },
    "@vue/compiler-sfc": {
      "optional": true
    },
    "knip": {
      "optional": true
    },
    "publint": {
      "optional": true
    },
    "svelte-check": {
      "optional": true
    },
    "tsx": {
      "optional": true
    },
    "typescript": {
      "optional": true
    },
    "vue-tsc": {
      "optional": true
    },
    "vue-tsgo": {
      "optional": true
    }
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas/tsconfig-schema.json": "./schemas/tsconfig-schema.json",
    "./package.json": "./package.json"
  },
  "sideEffects": false
}
