{
  "name": "@docs-islands/vitepress",
  "version": "0.3.0",
  "type": "module",
  "license": "MIT",
  "author": "Senao Xi",
  "description": "Cross-framework Islands Architecture for VitePress with multi-UI framework component rendering",
  "files": [
    "dist"
  ],
  "keywords": [
    "vitepress",
    "react",
    "islands-architecture",
    "cross-framework",
    "ssr",
    "hydration",
    "frontend"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XiSenao/docs-islands.git",
    "directory": "packages/vitepress"
  },
  "bugs": {
    "url": "https://github.com/XiSenao/docs-islands/issues"
  },
  "homepage": "https://docs.senao.me/docs-islands/vitepress",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "eslint . --config ./eslint.config.mjs --fix --cache --cache-location ./node_modules/.cache/eslint/",
    "lint:package": "lattice --config ../../lattice.config.mjs package check --package @docs-islands/vitepress",
    "lint:package:publint": "lattice --config ../../lattice.config.mjs package check --package @docs-islands/vitepress --tool publint",
    "lint:package:attw": "lattice --config ../../lattice.config.mjs package check --package @docs-islands/vitepress --tool attw",
    "lint:package:boundary": "lattice --config ../../lattice.config.mjs package check --package @docs-islands/vitepress --tool boundary",
    "smoke": "pnpm --dir ./smoke test",
    "typecheck": "lattice tsc && pnpm typecheck:theme",
    "typecheck:theme": "vue-tsc -p theme/tsconfig.lib.json --noEmit",
    "build": "rolldown --config rolldown.config.ts && pnpm build:theme && pnpm build-types-check",
    "build:theme": "rolldown --config rolldown.theme.config.ts",
    "build-types-check": "tsc -p tsconfig.check.json",
    "build:watch": "concurrently --names \"rolldown,theme\" --prefix-colors \"blue,magenta\" \"rolldown --config rolldown.config.ts --watch\" \"rolldown --config rolldown.theme.config.ts --watch\"",
    "test": "pnpm test:unit && pnpm --dir ./playground test:e2e",
    "test:unit": "vitest run",
    "clean": "del-cli  .tsbuild src/client/.tsbuild src/node/.tsbuild src/shared/.tsbuild .eslintcache dist coverage node_modules"
  },
  "imports": {
    "#types/*": "./types/*.d.ts",
    "#dep-types/*": "./src/types/*.d.ts",
    "#shared/constants/*": "./src/shared/constants/*.ts",
    "#shared/constants/log-groups/*": "./src/shared/constants/log-groups/*.ts",
    "#shared/*": "./src/shared/*.ts"
  },
  "dependencies": {
    "@docs-islands/logger": "workspace:*",
    "cheerio": "catalog:prod",
    "vite": "catalog:prod"
  },
  "devDependencies": {
    "@babel/generator": "catalog:dev",
    "@babel/parser": "catalog:dev",
    "@babel/traverse": "catalog:dev",
    "@babel/types": "catalog:dev",
    "@docs-islands/core": "workspace:*",
    "@docs-islands/eslint-config": "workspace:*",
    "@docs-islands/lattice": "link:../lattice/dist",
    "@docs-islands/plugin-license": "link:../plugins/license",
    "@docs-islands/utils": "link:../../utils/dist",
    "@types/babel__generator": "catalog:dev",
    "@types/babel__traverse": "catalog:dev",
    "@types/estree": "catalog:dev",
    "@types/markdown-it": "catalog:dev",
    "@types/node": "catalog:dev",
    "@types/react": "catalog:dev",
    "@types/react-dom": "catalog:dev",
    "@typescript-eslint/parser": "catalog:lint",
    "@vitejs/plugin-react-swc": "catalog:dev",
    "@vitejs/plugin-vue": "catalog:dev",
    "es-module-lexer": "catalog:dev",
    "eslint": "catalog:lint",
    "globals": "catalog:test",
    "htmlparser2": "catalog:dev",
    "jsdom": "catalog:test",
    "magic-string": "catalog:dev",
    "markdown-it": "catalog:dev",
    "prettier": "catalog:format",
    "vue-json-pretty": "catalog:dev",
    "shiki": "catalog:dev",
    "pathe": "catalog:dev",
    "playwright-chromium": "catalog:test",
    "picocolors": "catalog:dev",
    "react": "catalog:dev",
    "react-dom": "catalog:dev",
    "rolldown": "catalog:dev",
    "rolldown-plugin-dts": "catalog:dev",
    "vitepress": "catalog:frameworks",
    "vitest": "catalog:test",
    "vue": "catalog:prod",
    "vue-tsc": "catalog:dev",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev",
    "del-cli": "catalog:dev"
  },
  "peerDependencies": {
    "@types/node": "^20.19.0 || >=22.12.0",
    "@vitejs/plugin-react-swc": "catalog:dev",
    "react": "catalog:dev",
    "react-dom": "catalog:dev",
    "vue": "catalog:prod",
    "vitepress": "catalog:frameworks",
    "prettier": "catalog:format",
    "vue-json-pretty": "catalog:dev",
    "shiki": "catalog:dev"
  },
  "peerDependenciesMeta": {
    "@types/node": {
      "optional": true
    },
    "@vitejs/plugin-react-swc": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": false
    },
    "vitepress": {
      "optional": false
    },
    "prettier": {
      "optional": true
    },
    "vue-json-pretty": {
      "optional": true
    },
    "shiki": {
      "optional": true
    }
  },
  "exports": {
    ".": "./src/node/index.ts",
    "./client": "./src/client/index.ts",
    "./adapters/react": "./src/node/adapters/react/index.ts",
    "./adapters/react/client": "./src/client/adapters/react/index.ts",
    "./models": "./src/node/models.ts",
    "./logger": "./src/shared/logger.ts",
    "./logger/presets": "./src/shared/logger/presets.ts",
    "./devtools/client": {
      "types": "./types/devtools-client.d.ts",
      "default": "./theme/devtools.mjs"
    },
    "./devtools/client/style.css": {
      "types": "./types/theme.css.d.ts",
      "default": "./theme/devtools.css"
    },
    "./devtools/mcp": "./src/node/site-devtools/mcp.ts",
    "./package.json": "./package.json",
    "./internal/devtools": "./src/shared/internal/devtools.ts",
    "./internal/client-runtime": "./src/shared/internal/client-runtime.ts",
    "./internal-helper/client-runtime": "./dist/shared/internal/client-runtime.js",
    "./internal-helper/imports/types/*": "./types/*.d.ts",
    "./internal-helper/imports/dep-types/*": "./src/types/*.d.ts",
    "./internal-helper/imports/shared/constants/*": "./src/shared/constants/*.ts",
    "./internal-helper/imports/shared/constants/log-groups/*": "./src/shared/constants/log-groups/*.ts",
    "./internal-helper/imports/shared/*": "./src/shared/*.ts",
    "./types/*": {
      "types": "./types/*"
    }
  },
  "types": "./node/index.d.ts",
  "typesVersions": {
    "*": {
      "logger": [
        "./shared/logger.d.ts"
      ],
      "logger/presets": [
        "./shared/logger/presets.d.ts"
      ],
      "adapters/react": [
        "./node/adapters/react.d.ts"
      ],
      "adapters/react/client": [
        "./client/adapters/react.d.mts"
      ],
      "client": [
        "./client/index.d.mts"
      ],
      "models": [
        "./node/models.d.ts"
      ],
      "devtools/client": [
        "./types/devtools-client.d.ts"
      ],
      "devtools/client/style.css": [
        "./types/theme.css.d.ts"
      ],
      "devtools/mcp": [
        "./node/site-devtools/mcp.d.ts"
      ],
      "internal/devtools": [
        "./shared/internal/devtools.d.ts"
      ],
      "internal/client-runtime": [
        "./shared/internal/client-runtime.d.ts"
      ]
    }
  }
}
