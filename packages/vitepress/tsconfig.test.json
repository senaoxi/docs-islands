{
  // Package-local test check. Build leaf: tsconfig.test.build.json.
  "extends": "../../tsconfig.test.base.json",
  "compilerOptions": {
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "src/**/__tests__/**/*.ts",
    "src/**/__tests__/**/*.tsx",
    "scripts/**/__tests__/**/*.ts",
    "tests/**/*.ts",
    "vitest.config.ts"
  ]
}
