{
  "name": "@docs-islands/vitepress-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev",
    "docs:build": "pnpm clean:dist && wait-on -d 100 ../dist/node/index.js && vitepress build",
    "docs:preview": "vitepress preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --config ./eslint.config.mjs --fix --cache",
    "link:dev": "link-guard link:dev:exec",
    "link:dev:exec": "del-cli ../dist --force && npm pkg set devDependencies.@docs-islands/vitepress='link:../' && pnpm install",
    "link:prod": "link-guard link:prod:exec",
    "link:prod:exec": "del-cli ../dist --force && npm pkg set devDependencies.@docs-islands/vitepress='link:../dist' && pnpm --filter @docs-islands/vitepress build && pnpm install",
    "clean": "pnpm clean:remaining && del-cli .vitepress/dist .vitepress/cache .tsbuild .eslintcache node_modules",
    "clean:dist": "del-cli .vitepress/dist",
    "clean:remaining": "del-cli .vitepress/config.ts.timestamp-*.mjs || true"
  },
  "imports": {
    "#types/*": "@docs-islands/vitepress/internal-helper/imports/types/*",
    "#dep-types/*": "@docs-islands/vitepress/internal-helper/imports/dep-types/*",
    "#shared/constants/*": "@docs-islands/vitepress/internal-helper/imports/shared/constants/*",
    "#shared/constants/log-groups/*": "@docs-islands/vitepress/internal-helper/imports/shared/constants/log-groups/*",
    "#shared/*": "@docs-islands/vitepress/internal-helper/imports/shared/*"
  },
  "packageManager": "pnpm@10.33.4",
  "dependencies": {
    "react": "catalog:dev",
    "react-dom": "catalog:dev",
    "vue": "catalog:prod",
    "logaria": "catalog:prod"
  },
  "devDependencies": {
    "@types/react": "catalog:dev",
    "@rollup/plugin-replace": "catalog:dev",
    "eslint": "catalog:lint",
    "@docs-islands/eslint-config": "workspace:*",
    "@types/node": "catalog:dev",
    "typescript": "catalog:dev",
    "vue-tsc": "catalog:dev",
    "vitepress": "catalog:frameworks",
    "vitepress-plugin-group-icons": "catalog:docs-dev",
    "vitepress-plugin-llms": "catalog:docs-dev",
    "@nolebase/vitepress-plugin-enhanced-mark": "catalog:docs-dev",
    "@docs-islands/vitepress": "link:../dist",
    "@docs-islands/utils": "link:../../../utils/dist",
    "@vitejs/plugin-react-swc": "catalog:dev",
    "@vercel/analytics": "catalog:docs-dev",
    "vue-router": "catalog:dev",
    "vue-json-pretty": "catalog:dev",
    "tsx": "catalog:dev",
    "pathe": "catalog:dev",
    "rolldown": "catalog:dev",
    "rollup": "catalog:dev",
    "unplugin": "catalog:prod",
    "wait-on": "catalog:dev",
    "del-cli": "catalog:dev",
    "is-in-ci": "catalog:dev"
  }
}
