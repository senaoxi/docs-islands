{
  // Vue docs check used by vue-tsc via pnpm typecheck:vue; not native tsc -b.
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "isolatedDeclarations": false,
    "declaration": false,
  },
  "include": [
    "./",
    "./.vitepress/**/*.ts",
    "./.vitepress/theme/**/*.vue",
    "en/**/*.vue",
    "zh/**/*.vue",
  ],
}
