{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "isolatedDeclarations": false,
    "declaration": false,
    "allowJs": true,
    "lib": ["ESNext", "DOM"],
    "types": ["node"]
  },
  "include": [
    "eslint.config.mjs",
    "package.json",
    "packagePlugin.ts",
    "rolldown.config.ts",
    "rolldown.theme.config.ts",
    "scripts/**/*.ts"
  ]
}
