{
  "name": "@docs-islands/vitepress-playground",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev",
    "docs:build": "pnpm clean:e2e-fixtures && vitepress build",
    "docs:preview": "vitepress preview",
    "test:e2e": "vitest run",
    "test:e2e:watch": "DEBUG=1 vitest",
    "typecheck": "limina checker typecheck",
    "lint": "eslint . --config ./eslint.config.mjs --fix --cache",
    "clean": "pnpm clean:remaining && del-cli .tsbuild .eslintcache .vitepress/dist .vitepress/cache node_modules",
    "clean:remaining": "del-cli .vitepress/config.ts.timestamp-*.mjs error-handling/invalid-syntax.md error-handling/multiple-react-scripts.md script-content-changes/import-path-error.md || true",
    "clean:e2e-fixtures": "del-cli error-handling/invalid-syntax.md error-handling/multiple-react-scripts.md script-content-changes/import-path-error.md || true"
  },
  "dependencies": {
    "vue": "catalog:prod",
    "tinyglobby": "catalog:prod",
    "logaria": "workspace:*"
  },
  "devDependencies": {
    "eslint": "catalog:lint",
    "@typescript-eslint/parser": "catalog:lint",
    "@docs-islands/eslint-config": "workspace:*",
    "@docs-islands/utils": "link:../../../utils/dist",
    "limina": "link:../../limina/dist",
    "typescript": "catalog:dev",
    "react": "catalog:dev",
    "react-dom": "catalog:dev",
    "vite": "catalog:prod",
    "vitepress": "catalog:frameworks",
    "@docs-islands/vitepress": "link:../dist",
    "@vitejs/plugin-react-swc": "catalog:dev",
    "vitest": "catalog:test",
    "playwright-chromium": "catalog:test",
    "@playwright/test": "catalog:test",
    "get-port": "catalog:test",
    "del-cli": "catalog:dev"
  }
}
