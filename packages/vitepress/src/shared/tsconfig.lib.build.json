{
  "$schema": "https://json.schemastore.org/tsconfig",
  "lattice": "runtime-shared",
  // Shared runtime build leaf; node/client runtime projects depend on this leaf.
  "extends": ["./tsconfig.lib.json", "../../../../tsconfig.graph.base.json"],
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "./.tsbuild",
    "tsBuildInfoFile": "./.tsbuild/build.tsbuildinfo"
  },
  "references": [
    {
      "path": "../types/tsconfig.lib.build.json"
    },
    {
      "path": "../../../logger/tsconfig.lib.build.json"
    },
    {
      "path": "../../../core/tsconfig.lib.build.json"
    }
  ]
}
