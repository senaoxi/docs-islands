{
  // Runtime local check and rolldown-plugin-dts input. Build leaf: ./tsconfig.build.json.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "isolatedDeclarations": true,
    "declaration": true,
    "stripInternal": true,
