{
  "name": "@docs-islands/plugin-license",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "limina checker build tsconfig.dts.json",
    "build:watch": "limina checker build tsconfig.dts.json -w",
    "lint": "del-cli .eslintcache || true && eslint . --config ./eslint.config.mjs --fix --cache",
    "clean": "del-cli .tsbuild .eslintcache dist node_modules"
  },
  "types": "./dist/index.d.ts",
  "devDependencies": {
    "eslint": "catalog:lint",
    "limina": "workspace:*",
    "@docs-islands/eslint-config": "workspace:*",
    "@docs-islands/utils": "workspace:*",
    "rollup-plugin-license": "catalog:dev",
    "logaria": "catalog:prod",
    "rolldown": "catalog:dev",
    "del-cli": "catalog:dev",
    "typescript": "catalog:dev"
  },
  "peerDependencies": {
    "rolldown": "catalog:dev"
  },
  "peerDependenciesMeta": {
    "rolldown": {
      "optional": false
    }
  },
  "exports": {
    ".": "./dist/index.js"
  }
