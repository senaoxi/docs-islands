{
  "name": "@docs-islands/plugin-license",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rolldown --config rolldown.config.ts",
    "build:watch": "rolldown --config rolldown.config.ts --watch",
    "typecheck": "limina checker build",
    "lint": "del-cli .eslintcache || true && eslint . --config ./eslint.config.mjs --fix --cache",
    "clean": "del-cli .tsbuild .eslintcache dist node_modules"
  },
  "types": "./src/index.ts",
  "dependencies": {
    "logaria": "catalog:prod"
  },
  "devDependencies": {
    "eslint": "catalog:lint",
    "@docs-islands/eslint-config": "workspace:*",
    "@docs-islands/utils": "link:../../../utils/dist",
    "rolldown": "catalog:dev",
    "rolldown-plugin-dts": "catalog:dev",
    "rollup-plugin-license": "catalog:dev",
    "del-cli": "catalog:dev",
    "typescript": "catalog:dev"
  },
  "peerDependencies": {
    "rolldown": "catalog:dev"
  },
  "peerDependenciesMeta": {
    "rolldown": {
      "optional": false
    }
  },
  "exports": {
    ".": "./src/index.ts"
  }
