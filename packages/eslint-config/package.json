{
  "name": "@docs-islands/eslint-config",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "limina build tsconfig.dts.json --raw --preset tsc",
    "build:watch": "limina build tsconfig.dts.json --raw --preset tsc -w",
    "lint": "eslint . --config ./dist/general.js --fix --cache",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "del-cli .tsbuild .eslintcache dist node_modules"
  },
  "dependencies": {
    "tinyglobby": "catalog:prod"
  },
  "devDependencies": {
    "@types/eslint-plugin-jsx-a11y": "catalog:dev",
    "@eslint/js": "catalog:lint",
    "eslint": "catalog:lint",
    "eslint-config-prettier": "catalog:lint",
    "eslint-config-flat-gitignore": "catalog:lint",
    "eslint-plugin-regexp": "catalog:lint",
    "eslint-plugin-jsx-a11y": "catalog:lint",
    "eslint-plugin-prettier": "catalog:lint",
    "eslint-plugin-react": "catalog:lint",
    "eslint-plugin-n": "catalog:lint",
    "eslint-plugin-react-hooks": "catalog:lint",
    "eslint-plugin-unicorn": "catalog:lint",
    "eslint-plugin-pnpm": "catalog:lint",
    "@eslint/markdown": "catalog:lint",
    "@html-eslint/eslint-plugin": "catalog:lint",
    "@vitest/eslint-plugin": "catalog:test",
    "@html-eslint/parser": "catalog:lint",
    "eslint-plugin-vue": "catalog:lint",
    "vue-eslint-parser": "catalog:lint",
    "jsonc-eslint-parser": "catalog:lint",
    "yaml-eslint-parser": "catalog:lint",
    "prettier": "catalog:format",
    "@typescript-eslint/parser": "catalog:lint",
    "typescript-eslint": "catalog:lint",
    "typescript": "catalog:dev",
    "limina": "workspace:*",
    "globals": "catalog:test",
    "del-cli": "catalog:dev",
    "vitest": "catalog:test"
  },
  "exports": {
    ".": "./dist/general.js",
    "./presets": "./dist/presets/index.js",
    "./plugins": "./dist/plugins/index.js",
    "./config": "./dist/config/index.js",
    "./package.json": "./package.json"
  }
}
