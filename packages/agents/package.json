{
  "name": "@docs-islands/agents",
  "private": true,
  "type": "module",
  "description": "Shared AI assistant instructions and skills for Claude Code, Cursor, GitHub Copilot, and other AI coding tools",
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "link": "FORCE_COLOR=1 tsx scripts/link.ts",
