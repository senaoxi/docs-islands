{
  "$schema": "https://json.schemastore.org/tsconfig",
  // Tools declaration leaf. It must be split from lib, otherwise it will cause an error due to circular dependency.
  "extends": ["./tsconfig.tools.json", "../../tsconfig.dts.base.json"],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./.tsbuild",
    "tsBuildInfoFile": "./.tsbuild/tools.tsbuildinfo"
  },
  "references": [
    {
      "path": "./tsconfig.lib.dts.json"
    }
  ]
}
