{
  "name": "docs-islands-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.13.0",
    "pnpm": ">=10.33.4"
  },
  "workspaces": [
    "packages/*",
    "packages/*/docs",
    "packages/*/playground",
    "packages/plugins/*",
    "packages/**/__tests__/**",
    "docs",
    "utils"
  ],
  "homepage": "https://docs.senao.me/docs-islands",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XiSenao/docs-islands.git"
  },
  "description": "Cross-framework Islands Architecture for documentation sites",
  "keywords": [
    "docs-islands",
    "vitepress",
    "react",
    "islands-architecture",
    "cross-framework",
    "ssr",
    "hydration",
    "frontend"
  ],
  "scripts": {
    "build": "tsx scripts/build.ts",
    "docs:dev": "sh -c 'pnpm --filter \"@docs-islands/${1:-monorepo}-docs\" docs:dev' --",
    "docs:build": "pnpm run _run docs:build && tsx scripts/merge-docs.ts",
    "docs:preview": "pnpm --filter @docs-islands/monorepo-docs docs:preview",
    "docs:link:dev": "pnpm run _run link:dev",
    "docs:link:prod": "pnpm run _run link:prod",
    "test": "DOCS_ISLANDS_TEST='1' DOCS_ISLANDS_MODE='production' pnpm run build && concurrently --names \"test:unit,test:e2e\" --prefix-colors \"blue,orange\" --kill-others-on-fail \"pnpm run _run test:unit\" \"pnpm run _run test:e2e\"",
    "test:unit": "pnpm run _run test:unit",
    "test:e2e": "pnpm run _run test:e2e",
    "test:smoke": "pnpm run _run smoke vitepress",
    "lint": "eslint . --fix --cache --concurrency auto --config ./eslint.config.mjs && pnpm -r --parallel run lint",
    "lint:packages": "limina package check",
    "format": "prettier --write --cache .",
    "typecheck": "limina check",
    "typecheck:graph": "limina check graph",
    "tsconfig:graph:paths": "limina paths generate",
    "typecheck:lib": "limina check lib",
    "typecheck:vue": "limina check vue",
    "typecheck:consumer": "limina check consumer",
    "release": "tsx scripts/release.ts",
    "changelog": "tsx scripts/changelog.ts",
    "changelog:preview": "tsx scripts/changelog.ts --dry-run",
    "clean": "pnpm run _run clean && del-cli .tsbuild .eslintcache coverage node_modules",
    "_run": "tsx scripts/run-workspace-script.ts",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "node --import tsx scripts/postinstall.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "vite": "catalog:prod",
    "tinyglobby": "catalog:prod"
  },
  "devDependenciesComments": {
    "@playwright/test": "It ensures CI can execute playwright commands."
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "@types/prompts": "catalog:dev",
    "@typescript/native-preview": "catalog:dev",
    "@vue/compiler-sfc": "catalog:dev",
    "eslint": "catalog:lint",
    "@docs-islands/eslint-config": "workspace:*",
    "limina": "workspace:*",
    "logaria": "workspace:*",
    "@docs-islands/utils": "workspace:*",
    "prettier": "catalog:format",
    "prettier-plugin-organize-imports": "catalog:format",
    "typescript": "catalog:dev",
    "lint-staged": "catalog:dev",
    "vue-tsc": "catalog:dev",
    "vue-tsgo": "catalog:dev",
    "tsx": "catalog:dev",
    "cac": "catalog:dev",
    "prompts": "catalog:dev",
    "del-cli": "catalog:dev",
    "husky": "catalog:dev",
    "concurrently": "catalog:dev",
    "yaml": "catalog:dev",
    "@playwright/test": "catalog:test"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue,mjs,cjs}": [
      "eslint --cache --fix"
    ],
    "*": [
      "prettier --write --cache --ignore-unknown"
    ]
  },
  "packageManager": "pnpm@10.33.4"
}
